# Copy this file to .env and fill the values
# GOOGLE OAuth2 credentials (create in Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"your-service-account@your-project-id.iam.gserviceaccount.com","client_id":"your-client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project-id.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Root URL of your app (used to build redirect URI)
# Example for local dev:
ROOT_URL=http://localhost:3001

# Port the server listens on
PORT=3001

# Optional: override Chrome path for Puppeteer (not required here)
# CHROME_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=perikanan_db
DB_PORT=3306

# Server Configuration
NODE_ENV=development

# Admin auth security
# Required in production (minimum 32 characters)
ADMIN_TOKEN_SECRET=change-this-to-a-long-random-secret-min-32-chars
# 12 hours token TTL by default
ADMIN_TOKEN_TTL_SECONDS=43200
# Show detailed errors only for debugging (false in production)
ADMIN_SHOW_ERROR_DETAILS=false

# Optional health endpoint details in production
HEALTH_SHOW_DETAILS=false

# Optional DB checks interval (milliseconds)
DB_HEALTHCHECK_INTERVAL_MS=30000

# Optional admin auto-seed (recommended false in production)
ADMIN_AUTO_SEED=false
# ADMIN_DEFAULT_USERNAME=admin
# ADMIN_DEFAULT_PASSWORD=change-me
